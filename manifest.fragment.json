{
  "permissions": ["offscreen"],
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["wasm/*"]
    }
  ],
  "host_permissions": ["file://*/*"],
  "content_scripts": [
    {
      "matches": ["file://*/*"],
      "js": ["cnmd_viewer.js"],
      "run_at": "document_idle"
    }
  ]
}
